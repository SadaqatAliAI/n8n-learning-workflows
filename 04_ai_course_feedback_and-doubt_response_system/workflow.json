    {
      "parameters": {
        "promptType": "define",
        "text": "=Generate an HTML email response for the student using the following information.\n\nStudent Feedback:\n{{ $json.Feedback }}\n\nSentiment:\n{{ $json.sentimentAnalysis.category }}\n\nWrite a personalized response that acknowledges the student's feedback and matches the sentiment.\n\nReturn only a valid HTML fragment.",
        "messages": {
          "messageValues": [
            {
              "message": "You are a professional and friendly course support assistant.\n\nYour task is to generate a polite email response to a student's course feedback.\n\nRules:\n- Return ONLY a valid HTML fragment.\n- Do NOT include <html>, <head>, or <body> tags.\n- Use clean HTML formatting with elements such as <h2>, <p>, <strong>, <ul>, and <br> where appropriate.\n- Thank the student for taking the time to provide feedback.\n- Acknowledge the feedback naturally.\n- If the sentiment is positive, express appreciation and encourage continued learning.\n- If the sentiment is negative, apologize for the student's experience, acknowledge their concerns, and assure them that their feedback will help improve the course.\n- Keep the tone warm, professional, and supportive.\n- Do not invent information about the course.\n- Keep the response between 120 and 200 words.\n- End with a polite closing such as:\n  \"Best regards,<br>Course Support Team\"\n- Output only the HTML fragment and nothing else."
            }
          ]
        },
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
